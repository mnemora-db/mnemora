# Mnemora Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ──────────────────────────────────────────────
# API Configuration
# ──────────────────────────────────────────────

# Base URL of the deployed Mnemora API (from CDK output: MnemoraApiEndpoint)
MNEMORA_API_URL=https://YOUR_API_ID.execute-api.us-east-1.amazonaws.com

# API key for authentication (Bearer token)
MNEMORA_API_KEY=your-api-key-here

# ──────────────────────────────────────────────
# Aurora PostgreSQL (pgvector)
# ──────────────────────────────────────────────

# Aurora cluster writer endpoint (from CDK output: AuroraClusterEndpoint)
AURORA_ENDPOINT=your-cluster.cluster-xxxxxxxxxxxx.us-east-1.rds.amazonaws.com

# Aurora PostgreSQL port
AURORA_PORT=5432

# Secrets Manager ARN for Aurora credentials (from CDK output: AuroraSecretArn)
AURORA_SECRET_ARN=arn:aws:secretsmanager:us-east-1:YOUR_ACCOUNT_ID:secret:mnemora/aurora/dev/credentials-XXXXXX

# Database name
AURORA_DB_NAME=mnemora

# ──────────────────────────────────────────────
# DynamoDB
# ──────────────────────────────────────────────

# DynamoDB table name (from CDK output: StateTableName)
STATE_TABLE_NAME=mnemora-state-dev

# ──────────────────────────────────────────────
# S3 (Episodic Cold Storage)
# ──────────────────────────────────────────────

# S3 bucket for episodic memory cold storage (from CDK output: EpisodeBucketName)
EPISODE_BUCKET_NAME=mnemora-episodes-dev-YOUR_ACCOUNT_ID

# ──────────────────────────────────────────────
# AWS Configuration
# ──────────────────────────────────────────────

# AWS region
AWS_REGION=us-east-1

# AWS account ID (used by CDK)
CDK_DEFAULT_ACCOUNT=YOUR_ACCOUNT_ID

# CDK default region
CDK_DEFAULT_REGION=us-east-1

# ──────────────────────────────────────────────
# Bedrock (Embeddings)
# ──────────────────────────────────────────────

# Bedrock embedding model ID
BEDROCK_EMBEDDING_MODEL=amazon.titan-embed-text-v2:0

# Embedding dimensions
BEDROCK_EMBEDDING_DIMS=1024

# ──────────────────────────────────────────────
# Dashboard (Next.js)
# ──────────────────────────────────────────────

# Dashboard API URL (same as MNEMORA_API_URL)
NEXT_PUBLIC_API_URL=https://YOUR_API_ID.execute-api.us-east-1.amazonaws.com
